# ========================================
# GCJ OFFICIAL WEBSITE - ENVIRONMENT VARIABLES
# Government College Jhang
# ========================================

# ----- Django Core -----
SECRET_KEY=your-super-secret-django-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,gcj.edu.pk,www.gcj.edu.pk
DJANGO_SETTINGS_MODULE=gcj_backend.settings.production

# ----- Database (MySQL) -----
DB_ENGINE=django.db.backends.mysql
DB_NAME=gcj_database
DB_USER=gcj_user
DB_PASSWORD=strong_password_here
DB_HOST=localhost
DB_PORT=3306

# ----- JWT Authentication -----
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ----- Google Gemini AI -----
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MAX_TOKENS=8192

# ----- Redis (Celery Broker) -----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ----- Email Configuration -----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=gcjofficial@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
DEFAULT_FROM_EMAIL=GCJ Official <gcjofficial@gmail.com>

# ----- AWS S3 Storage (Production) -----
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=gcj-media-bucket
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_CUSTOM_DOMAIN=your-cloudfront-domain.cloudfront.net

# ----- CORS -----
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://gcj.edu.pk

# ----- Frontend -----
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_GEMINI_API_KEY=your-gemini-api-key-here
VITE_SITE_NAME=GCJ Official Website
VITE_SITE_URL=https://gcj.edu.pk

# ----- Sentry (Error Monitoring) -----
SENTRY_DSN=your-sentry-dsn-here

# ----- Security -----
CSRF_TRUSTED_ORIGINS=https://gcj.edu.pk,https://www.gcj.edu.pk
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
